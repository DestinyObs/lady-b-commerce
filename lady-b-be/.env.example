# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ladyb:<DB_PASSWORD>@localhost:5432/ladybcommerce

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=<REPLACE_WITH_RANDOM_32_CHAR_STRING>
JWT_REFRESH_SECRET=<REPLACE_WITH_RANDOM_32_CHAR_STRING>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<sk_test_REPLACE_WITH_YOUR_STRIPE_KEY>
STRIPE_WEBHOOK_SECRET=<whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET>
STRIPE_CURRENCY=usd

# ─── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=<REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID>
PAYPAL_CLIENT_SECRET=<REPLACE_WITH_YOUR_PAYPAL_CLIENT_SECRET>
PAYPAL_WEBHOOK_ID=<REPLACE_WITH_YOUR_PAYPAL_WEBHOOK_ID>
PAYPAL_MODE=sandbox

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<REPLACE_WITH_YOUR_CLOUD_NAME>
CLOUDINARY_API_KEY=<REPLACE_WITH_YOUR_CLOUDINARY_KEY>
CLOUDINARY_API_SECRET=<REPLACE_WITH_YOUR_CLOUDINARY_SECRET>
CLOUDINARY_FOLDER=lady-b-commerce

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<REPLACE_WITH_YOUR_SMTP_EMAIL>
SMTP_PASS=<REPLACE_WITH_YOUR_APP_PASSWORD>
EMAIL_FROM="Lady B Designs <no-reply@ladybdesigns.com>"
ADMIN_EMAIL=Adebiyiblessing55@gmail.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── App ──────────────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=USD
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
BRAND_NAME=Lady B Designs and Handcraft

# ─── Upload Limits ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/avif
